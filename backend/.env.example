# App Configuration
PORT=8080
NODE_ENV=production

# Trust Proxy Configuration (Set to 1 or comma-separated proxy IPs behind Cloudflare/Load Balancer)
# CRITICAL: Prevents IP spoofing via X-Forwarded-For headers while keeping rate limiting accurate.
TRUST_PROXY=1

# CORS Configuration
# Comma-separated list of allowed origins. Do NOT use wildcards '*' in production.
ALLOWED_ORIGINS=https://arenasync.fifa2026.com,https://staging.arenasync.fifa2026.com,http://localhost:8081,http://localhost:8080

# Distributed Rate Limiting (Redis connection URL)
# Used to synchronize rate limit states across multiple clustered server instances.
REDIS_URL=redis://localhost:6379

# Rate Limit Config Defaults
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Authentication (JWT Setup)
# Generate a secure secret using: openssl rand -base64 32
JWT_SECRET=super_secure_random_base64_secret_key_here
JWT_EXPIRES_IN=1h

# Generative AI Configuration
# The server will automatically use the Google GenAI SDK if this key is set.
# If not set, it will fallback gracefully to local rule-based intelligence.
GEMINI_API_KEY=
